# By Heart — environment template. Copy to `.env` (gitignored) and fill in.
# NEVER commit a real key. The MVP uses the Gemini API directly (AI Studio),
# not Vertex AI, so no GCP project/credentials are required.

# Gemini API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Use the Gemini API directly rather than Vertex AI.
GOOGLE_GENAI_USE_VERTEXAI=False
